{
  "_note": "SAMPLE / DEMO DATA — for prototype only. Intake questions used to generate a personalized VetPath gameplan. Not official VA guidance. allowCustom on a question lets the veteran type their own answer; every step also offers a free-response notes box.",
  "stepNotesPrompt": "Anything else about your situation we should know? (optional, your words)",
  "steps": [
    {
      "id": "basics",
      "title": "The basics",
      "subtitle": "Helps us tailor timing and state resources.",
      "questions": [
        {
          "id": "ageRange",
          "label": "What is your age range?",
          "type": "single",
          "options": ["Under 25", "25–34", "35–44", "45–54", "55–64", "65+"]
        },
        {
          "id": "state",
          "label": "Which state(s) do you live in?",
          "type": "multistate",
          "helper": "Select all that apply — add every state where you keep a home or rental, or split your year. State benefits and taxes vary, so we track them all and factor them into your Compare-states and relocation tools."
        },
        {
          "id": "city",
          "label": "What city or town? (optional)",
          "type": "text",
          "optional": true,
          "placeholder": "e.g. San Antonio",
          "helper": "Helps us think about VA facility access and local resources."
        },
        {
          "id": "sex",
          "label": "What is your sex?",
          "type": "single",
          "optional": true,
          "allowCustom": true,
          "options": ["Male", "Female", "Prefer not to say"],
          "helper": "Why we ask: some programs specifically serve women veterans (health services, V-WISE entrepreneurship). Sharing is optional and only personalizes suggestions."
        },
        {
          "id": "raceEthnicity",
          "label": "Race / ethnicity? (optional — select any)",
          "type": "multi",
          "optional": true,
          "allowCustom": true,
          "options": ["American Indian / Alaska Native", "Asian", "Black / African American", "Hispanic / Latino", "Native Hawaiian / Pacific Islander", "White", "Prefer not to say"],
          "helper": "Why we ask: some business and support programs specifically serve minority veterans (e.g., MBDA centers). Optional, never required, never shared."
        },
        {
          "id": "branch",
          "label": "Which branch did you serve in?",
          "type": "single",
          "options": ["Army", "Navy", "Air Force", "Marine Corps", "Coast Guard", "Space Force", "National Guard / Reserve"]
        },
        {
          "id": "serviceEra",
          "label": "When did you serve?",
          "type": "single",
          "options": ["Currently serving", "Post-9/11 (2001–present)", "Gulf War (1990–2001)", "Cold War / peacetime", "Vietnam era", "Other / not sure"]
        }
      ]
    },
    {
      "id": "status",
      "title": "Where you are right now",
