        {
          "id": "disabilityRating",
          "label": "Do you have a VA disability rating? (optional)",
          "type": "single",
          "optional": true,
          "options": ["None / not rated", "Claim pending or filing", "0–20%", "30–50%", "60–90%", "100%", "Prefer not to say"]
