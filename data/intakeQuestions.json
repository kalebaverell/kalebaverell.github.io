          "label": "Family or dependent needs?",
          "type": "multi",
          "allowCustom": true,
          "options": ["Spouse benefits", "Dependent education", "Childcare", "Caregiver support", "None"]
        }
      ]
    },
    {
      "id": "weights",
      "title": "What matters most",
