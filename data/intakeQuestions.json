        {
          "id": "businessInterest",
          "label": "Interested in owning a business?",
          "type": "single",
          "options": ["Yes — actively working on it", "Yes — someday", "No"]
        },
        {
          "id": "wellnessPriorities",
          "label": "Health & wellness priorities?",
          "type": "multi",
          "allowCustom": true,
          "options": ["Mental health support", "VA healthcare / physical health", "Fitness", "Community & connection", "None right now"]
        },
        {
          "id": "financialPriorities",
