          "dims": [
            { "key": "career", "label": "Career & work", "icon": "ti-briefcase" },
            { "key": "money", "label": "Money & benefits", "icon": "ti-coin" },
            { "key": "education", "label": "Education", "icon": "ti-school" },
            { "key": "family", "label": "Family", "icon": "ti-users" },
            { "key": "health", "label": "Health & wellness", "icon": "ti-heartbeat" },
            { "key": "business", "label": "Business ownership", "icon": "ti-building-store" },
            { "key": "stability", "label": "Stability & housing", "icon": "ti-home" }
          ]
        }
      ]
    },
    {
      "id": "goals",
      "title": "Your top goals",
      "subtitle": "Choose up to 3. These drive your gameplan.",
      "questions": [
        {
          "id": "topGoals",
          "label": "What are your top 3 goals right now?",
          "type": "goals",
          "max": 3
        },
        {
          "id": "urgency",
          "label": "How urgent does this feel?",
          "type": "single",
          "options": ["Right now — I need help urgently", "Next 1–3 months", "Next 6–12 months", "Just exploring"]
        }
      ]
