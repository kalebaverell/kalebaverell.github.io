        {
          "id": "employment",
          "label": "What is your employment situation?",
          "type": "single",
          "options": ["Employed full-time", "Employed part-time", "Unemployed / job seeking", "Self-employed / business owner", "Student", "Retired", "Unable to work right now"]
        },
        {
          "id": "housing",
          "label": "What is your housing situation?",
          "type": "multi",
          "options": ["Rent", "Own a home", "Own property in another state", "Living with family", "Unstable / at risk", "Currently homeless"]
